[Unit]
Description=Career-Ops AI Scoring Service
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/scoring-service
Environment=CAREER_OPS_DIR=/opt/career-ops
Environment=PORT=5000
ExecStart=/opt/scoring-service/venv/bin/gunicorn -w 2 -b 0.0.0.0:5000 --timeout 300 app:app
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
